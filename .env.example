## All values in this file are server-only.
## Do not expose them as NEXT_PUBLIC_* env vars.

NODE_ENV=development

## Local writable data root.
DATA_DIR=/absolute/path/to/ad-video-agent/.data

## Local SQLite database path. Must be absolute.
SQLITE_DB_PATH=/absolute/path/to/ad-video-agent/.data/deal-pump.sqlite

## Local artifact root. Must be absolute.
ARTIFACTS_DIR=/absolute/path/to/ad-video-agent/.data/artifacts

## Locked to 1 for SQLite safety.
WORKER_CONCURRENCY=1

## Local development can keep this false if ffmpeg is not installed.
## Production should set this to true.
REQUIRE_FFMPEG=false

## Recommended locally, required for any public deployment.
## Use a strong random secret in production.
ARTIFACT_ROUTE_SIGNING_SECRET=dev-artifact-route-secret

## Optional local web port.
PORT=3000

## AI provider runtime mode:
## - fixture: deterministic no-secrets path (default)
## - live: use real OpenAI + Vertex AI providers
AI_PROVIDER_MODE=fixture

## Required when AI_PROVIDER_MODE=live
OPENAI_API_KEY=

## Required when AI_PROVIDER_MODE=live
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1

## Optional (defaults to v1)
VERTEX_API_VERSION=v1

## Optional: absolute path to service-account JSON key.
## If omitted, runtime uses Application Default Credentials (ADC).
GOOGLE_APPLICATION_CREDENTIALS=

## Production reference only.
## NODE_ENV=production
## DATA_DIR=/data
## SQLITE_DB_PATH=/data/deal-pump.sqlite
## ARTIFACTS_DIR=/data/artifacts
## WORKER_CONCURRENCY=1
## REQUIRE_FFMPEG=true
## ARTIFACT_ROUTE_SIGNING_SECRET=replace-with-a-strong-random-secret
## PORT=3000
## AI_PROVIDER_MODE=live
## OPENAI_API_KEY=replace-with-openai-key
## VERTEX_PROJECT=your-gcp-project-id
## VERTEX_LOCATION=us-central1
## VERTEX_API_VERSION=v1
## GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
