{
  "name": "ad-video-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/start-web.ts dev",
    "web:dev": "next dev",
    "build": "next build",
    "start": "tsx scripts/start-web.ts start",
    "web:start": "next start",
    "lint": "eslint app worker packages scripts tests",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:security": "vitest run tests/security",
    "test:e2e": "playwright test",
    "verify": "pnpm lint && pnpm typecheck && pnpm test:unit && pnpm test:integration && pnpm test:security && pnpm build",
    "worker:dev": "tsx watch worker/src/index.ts",
    "worker:start": "tsx worker/src/index.ts",
    "dev:full": "tsx scripts/dev-full.ts",
    "run-engine:check": "tsx scripts/run-engine-check.ts"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@google/genai": "^1.29.0",
    "next": "16.2.2",
    "openai": "^6.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
